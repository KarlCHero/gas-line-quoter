# CheckHero Gas Line Quoter — environment
# Copy to .env.local and fill in. The anon/publishable key is safe to ship to the
# browser; Row-Level Security policies on the database are what protect the data.

PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# Set to "true" to run entirely on in-memory data with no network/database access
# (for demos). Leave unset/false for normal use.
PUBLIC_DEMO_MODE=false
